  <h2 class="govuk-heading-m">Cookie Banner</h2>
  <hr class="govuk-section-break govuk-section-break--s govuk-!-margin-bottom-5 govuk-section-break--visible">

  <div class="example-grid">
    <div>
      <h3 class="govuk-heading-s">Now</h3>
      {% set cookieBannerHtml %}
        <p class="govuk-body">We use some essential cookies to make this service work.</p>
        <p class="govuk-body">We’d also like to use analytics cookies so we can understand how you use the service and make improvements.</p>
      {% endset %}

      {{ govukCookieBanner({
        ariaLabel: "Cookies on [name of service]",
        messages: [
          {
            headingText: "Cookies on [name of service]",
            html: cookieBannerHtml,
            actions: [
              {
                text: "Accept analytics cookies",
                type: "button"
              },
              {
                text: "Reject analytics cookies",
                type: "button"
              },
              {
                text: "View cookies",
                href: "#"
              }
            ]
          }
        ]
      }) }}
    </div>
    <div>
      <h3 class="govuk-heading-s">(Brand) Surface</h3>
      <style>
        .govuk-input__wrapper--surfaced {
          .govuk-input__prefix,
          .govuk-input__suffix {
            color: var(--govuk-surface-text-colour);
            background-color: var(--govuk-surface-background-colour);
            --govuk-input-border-colour: var(--govuk-surface-border-colour);
          }
        }
      </style>
      {{ govukCookieBanner({
        classes: "govuk-cookie-banner--surfaced",
        ariaLabel: "Cookies on [name of service]",
        messages: [
          {
            headingText: "Cookies on [name of service]",
            html: cookieBannerHtml,
            actions: [
              {
                text: "Accept analytics cookies",
                type: "button"
              },
              {
                text: "Reject analytics cookies",
                type: "button"
              },
              {
                text: "View cookies",
                href: "#"
              }
            ]
          }
        ]
      }) }}
    </div>
    <div>
      <h3 class="govuk-heading-s">Generic Surface</h3>
      <style>
        .govuk-cookie-banner--generic-surfaced {
          --govuk-brand-colour: grey;
          --govuk-surface-border-colour: var(--govuk-generic-surface-border-colour);
          --govuk-surface-background-colour: var(--govuk-generic-surface-background-colour);
          --govuk-template-background-colour: var(--govuk-surface-background-colour);
          /* uses the background colour since the html background colour of the page 'extends' the footer */
          --govuk-surface-border-colour: var(--govuk-generic-surface-border-colour);
        }
      </style>
      {{ govukCookieBanner({
        classes: "govuk-cookie-banner--generic-surfaced",
        ariaLabel: "Cookies on [name of service]",
        messages: [
          {
            headingText: "Cookies on [name of service]",
            html: cookieBannerHtml,
            actions: [
              {
                text: "Accept analytics cookies",
                type: "button"
              },
              {
                text: "Reject analytics cookies",
                type: "button"
              },
              {
                text: "View cookies",
                href: "#"
              }
            ]
          }
        ]
      }) }}
    </div>
  </div>

  <hr class="govuk-section-break govuk-section-break--l govuk-!-margin-bottom-9 govuk-section-break--visible">

{% endblock %}
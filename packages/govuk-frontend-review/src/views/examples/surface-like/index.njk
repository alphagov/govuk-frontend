  <h2 class="govuk-heading-m">Text input</h2>
  <hr class="govuk-section-break govuk-section-break--s govuk-!-margin-bottom-5 govuk-section-break--visible">

  <div class="example-grid">
    <div>
      <h3 class="govuk-heading-s">Now</h3>
      {{ govukInput({
        id: "cost-per-item",
        name: "costPerItem",
        label: {
          text: "What is the cost per item, in pounds?",
          classes: "govuk-label--l",
          isPageHeading: true
        },
        prefix: {
          text: "£"
        },
        suffix: {
          text: "per item"
        },
        classes: "govuk-input--width-5",
        spellcheck: false
      }) }}
    </div>
    <div>
      <h3 class="govuk-heading-s">(Brand) Surface</h3>
      <style>
        .govuk-input__wrapper--surfaced {
          .govuk-input__prefix,

  <style>
    :root {
      --govuk-generic-surface-background-colour: #f3f3f3;
      --govuk-generic-surface-border-colour: var(--govuk-border-colour);
      --govuk-generic-surface-text-colour: var(--govuk-text-colour);

      --govuk-inverse-surface-background-colour: var(--govuk-brand-colour);
      --govuk-inverse-surface-border-colour: var(--govuk-brand-colour);
      --govuk-inverse-surface-text-colour: #ffffff;
    }
    /* On large screens make use of the screen */
    @media (min-width: 1900px) {
      /* make page bigger to see more content */
      .govuk-width-container {
        max-width: 90vw;
      }
      /* hack the grid so sticky positioning works correctly */
      [class^=govuk-grid] {
        all: unset;
      }
      .example-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
      }
    }
  </style>


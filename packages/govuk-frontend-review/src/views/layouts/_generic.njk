{% extends "govuk/template.njk" %}

{% block head %}
  <link rel="stylesheet" href="/stylesheets/app.min.css">

  {% block styles %}{% endblock %}
{% endblock %}

{% block bodyStart %}
  {% block banner %}
    {% include "../partials/banner.njk" %}
  {% endblock %}
  <div class="govuk-width-container">
    <a class="govuk-link" href="/{{ 'recolour-off' if useRecolourClass else 'recolour-on' }}">
      Use {{ 'old' if useRecolourClass else 'new' }} colours
    </a>
  </div>
{% endblock %}

{% set mainClasses = 'govuk-main-wrapper--auto-spacing' %}

{% block bodyEnd %}
  <script type="module" src="/javascripts/govuk-frontend.min.js"></script>
  <script type="module">
    import { initAll } from '/javascripts/govuk-frontend.min.js'
    initAll()
  </script>
{% endblock %}

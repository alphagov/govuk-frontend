{% from "../../macros/attributes.njk" import govukAttributes -%}

{% set headingLevel = params.headingLevel if params.headingLevel else 1 -%}

{%- set hasModifierClassName = params.classes and ("govuk-panel--" in params.classes)-%}

{#- The Panel component defaults to the Confirmation variant -#}
{#- If the user provides their own modifier class then use that instead. -#}
{%- set defaultModifierClassName = "govuk-panel--confirmation" if not hasModifierClassName -%}

<div class="govuk-panel
  {%- if defaultModifierClassName %} {{ defaultModifierClassName }}{% endif %}
  {%- if params.classes %} {{ params.classes }}{% endif -%}
"
  {{- govukAttributes(params.attributes) }}>
  <h{{ headingLevel }} class="govuk-panel__title {%- if params.titleClasses %} {{ params.titleClasses }}{% endif -%}">
    {{ params.titleHtml | safe if params.titleHtml else params.titleText }}
  </h{{ headingLevel }}>
  {% if caller or params.html or params.text %}
  <div class="govuk-panel__body">
    {{ caller() if caller else (params.html | safe | trim | indent(4) if params.html else params.text) }}
  </div>
  {% endif %}
</div>
